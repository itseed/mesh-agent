# PostgreSQL
DATABASE_URL=postgresql://meshagent:meshagent@localhost:5432/meshagent
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379

# Auth — initial admin user (gets seeded into DB on first boot if no users exist)
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD=changeme123
JWT_SECRET=change-this-to-a-random-64-char-string
# AES-256-GCM key used to encrypt secrets at rest (GitHub tokens, OAuth credentials).
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=change-this-to-a-random-32+-char-string

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# CORS — required in production. Comma-separated list of allowed browser origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cookies — set this to your domain in production (e.g. .yourdomain.com) so the
# JWT cookie is shared across api and web subdomains. Leave empty in dev.
COOKIE_DOMAIN=

# Rate limits (Fastify @fastify/rate-limit syntax for time windows)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=1 minute

# GitHub — fallback PAT if a user hasn't connected via Settings yet
GITHUB_TOKEN=
# REQUIRED in production. Min 16 chars. openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# GitHub OAuth — optional. Enables the "Authenticate via GitHub" button on the
# Settings page. Without these the page falls back to PAT-only entry.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3001/settings/github/oauth/callback
WEB_BASE_URL=http://localhost:3000

# Orchestrator
ORCHESTRATOR_URL=http://localhost:3002
MAX_CONCURRENT_SESSIONS=8
SESSION_IDLE_TIMEOUT_MS=3600000
CLAUDE_CMD=claude

# Backups
BACKUP_RETENTION_DAYS=14
