# PostgreSQL
DATABASE_URL=postgresql://meshagent:meshagent@localhost:5432/meshagent

# Redis
REDIS_URL=redis://localhost:6379

# Auth — single user
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD=changeme
JWT_SECRET=change-this-to-a-random-64-char-string

# Server
PORT=3001
NODE_ENV=development

# GitHub — fallback PAT if a user hasn't connected via Settings yet
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# GitHub OAuth — optional. Enables the "Authenticate via GitHub" button on the
# Settings page. Without these the page falls back to PAT-only entry.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3001/settings/github/oauth/callback
WEB_BASE_URL=http://localhost:3000
