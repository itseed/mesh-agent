# Database
DB_USER=meshagent
DB_NAME=meshagent
DB_PASSWORD=change-this-strong-password
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30

# Auth — initial admin (only seeded on first boot; subsequent users via /auth/users)
AUTH_EMAIL=admin@yourdomain.com
AUTH_PASSWORD=change-this-strong-password
JWT_SECRET=change-this-to-64-random-chars
# REQUIRED. AES-256-GCM key. openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=change-this-to-32-random-chars

# CORS — REQUIRED in production. Comma-separated. No spaces.
CORS_ALLOWED_ORIGINS=https://meshagent.yourdomain.com

# Cookie domain — leave empty if API and web share the same host;
# set to .yourdomain.com if served from sub-domains.
COOKIE_DOMAIN=

# Rate limits
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=1 minute

# Domain
DOMAIN=meshagent.yourdomain.com

# Logging
LOG_LEVEL=info

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# GitHub
GITHUB_TOKEN=
# REQUIRED in production. openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=change-this-webhook-secret

# GitHub OAuth (optional)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://meshagent.yourdomain.com/api/settings/github/oauth/callback
WEB_BASE_URL=https://meshagent.yourdomain.com

# Orchestrator
MAX_CONCURRENT_SESSIONS=16
SESSION_IDLE_TIMEOUT_MS=3600000
CLAUDE_CMD=claude

# Backups
BACKUP_RETENTION_DAYS=30
