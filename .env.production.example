# Database
DB_USER=meshagent
DB_PASSWORD=change-this-strong-password

# Auth
AUTH_EMAIL=admin@yourdomain.com
AUTH_PASSWORD=change-this-strong-password
JWT_SECRET=change-this-to-64-random-chars

# Domain
DOMAIN=meshagent.yourdomain.com

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=change-this-webhook-secret

# GitHub OAuth (optional — enables Settings ⇒ "Authenticate via GitHub")
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://meshagent.yourdomain.com/api/settings/github/oauth/callback
WEB_BASE_URL=https://meshagent.yourdomain.com
