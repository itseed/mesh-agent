{
  "name": "meshagent",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,orch,web -c yellow,cyan,magenta \"pnpm --filter api dev\" \"pnpm --filter @meshagent/orchestrator dev\" \"pnpm --filter web dev\"",
    "dev:api": "pnpm --filter api dev",
    "dev:orchestrator": "pnpm --filter @meshagent/orchestrator dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r --if-present --no-bail lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.6",
    "prettier": "^3.3.3"
  }
}
